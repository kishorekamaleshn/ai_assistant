# Security Warning!
# NEVER commit your actual .env file.
# This is an example file. Copy it to .env and fill in the values.

# Secret key used to sign JWT tokens. Keep this safe in production!
JWT_SECRET=super_secret_test_key_change_me_in_production

# Google Gemini API Key
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini model to use (see https://ai.google.dev/gemini-api/docs/models)
GEMINI_MODEL=gemini-3.1-flash-lite-preview
